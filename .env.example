# Copy to .env — never commit .env to git
# These override values in config.yml

PLEX_TOKEN_STREAMSTEAD=your_streamstead_plex_token
PLEX_TOKEN_STREAMSTEAD_UNLIMITED=your_unlimited_plex_token

# Debrid provider API keys (optional — used for provider health checks)
RD_API_KEY=your_realdebrid_api_key
AD_API_KEY=your_alldebrid_api_key
TB_API_KEY=your_torbox_api_key
DL_API_KEY=your_debridlink_api_key

DISCORD_WEBHOOK=https://discord.com/api/webhooks/your/webhook
