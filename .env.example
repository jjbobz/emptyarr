# Copy this to .env and fill in your values.
# .env is gitignored — never commit it.
#
# These variables override matching values in config.yml.
# For local development with docker compose only —
# on Unraid set these directly in the Docker UI instead.

# ── Plex tokens ───────────────────────────────────────────────────────────────
# One variable per Plex instance, named after the instance name in config.yml:
# uppercased, spaces and hyphens replaced with underscores.
#
# Examples:
#   Instance name "My Plex"      → PLEX_TOKEN_MY_PLEX=xxxxx
#   Instance name "Plex-4K"      → PLEX_TOKEN_PLEX_4K=xxxxx
#   Instance name "HomeServer"   → PLEX_TOKEN_HOMESERVER=xxxxx
#
PLEX_TOKEN_MY_INSTANCE=your_plex_token_here
# PLEX_TOKEN_MY_OTHER_INSTANCE=your_other_token_here

# ── Debrid provider API keys (optional) ───────────────────────────────────────
# Leave blank or remove lines you don't need.
RD_API_KEY=your_realdebrid_api_key
# AD_API_KEY=your_alldebrid_api_key
# TB_API_KEY=your_torbox_api_key
# DL_API_KEY=your_debridlink_api_key

# ── Notifications ─────────────────────────────────────────────────────────────
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your/webhook

# ── Other ─────────────────────────────────────────────────────────────────────
TZ=America/New_York
# LOG_LEVEL=INFO
