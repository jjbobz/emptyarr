# emptyarr config
# Copy this to config.yml and fill in your values.
# Values here are overridden by environment variables — see docker-compose.yml.

discord_webhook: "https://discord.com/api/webhooks/YOUR/WEBHOOK"

notify:
  on_success: false   # Send Discord message when trash is successfully emptied
  on_failure: true    # Send when health checks fail and trash empty is skipped
  on_skip:    true    # Send when something prevents the run (section not found etc.)

plex_instances:

  # ── Streamstead — physical media only ──────────────────────────────────────
  - name: "Streamstead"
    url:   "http://10.10.10.5:32400"
    token: "YOUR_PLEX_TOKEN_STREAMSTEAD"

    libraries:
      - name: Movies
        type: physical
        cron: "0 * * * *"         # every hour
        paths:
          - path: /media/physical/movies
            type: physical
            min_files: 200         # abort if fewer than 200 files found on disk
            min_threshold: 95      # abort if disk files < 95% of Plex library count

      - name: TV Shows
        type: physical
        cron: "0 * * * *"
        paths:
          - path: /media/physical/tv
            type: physical
            min_files: 500
            min_threshold: 95

  # ── Streamstead-Unlimited — mixed physical + debrid ─────────────────────────
  - name: "Streamstead-Unlimited"
    url:   "http://10.10.10.5:32410"
    token: "YOUR_PLEX_TOKEN_STREAMSTEAD_UNLIMITED"

    libraries:
      - name: Movies
        type: mixed
        cron: "*/30 * * * *"      # every 30 minutes
        paths:
          - path: /media/symlinks/movie
            type: debrid
            min_files: 200
            min_threshold: 90
            provider_checks:
              - type: realdebrid
                api_key: ""       # leave blank to use RD_API_KEY env var

          - path: /media/physical/movies
            type: physical
            min_files: 100
            min_threshold: 95

      - name: TV Shows
        type: mixed
        cron: "*/30 * * * *"
        paths:
          - path: /media/symlinks/tv
            type: debrid
            min_files: 500
            min_threshold: 90
            provider_checks:
              - type: realdebrid
                api_key: ""       # leave blank to use RD_API_KEY env var

          - path: /media/physical/tv
            type: physical
            min_files: 200
            min_threshold: 95

# ── Notes ───────────────────────────────────────────────────────────────────
#
# Library types:
#   physical — real files on disk, no symlink check, no provider API check
#   debrid   — symlinks pointing to a debrid/rclone mount, full symlink check
#   usenet   — symlinks pointing to a usenet mount (future support)
#   mixed    — per-path type declarations (physical + debrid in same Plex library)
#
# provider_checks (optional, per path):
#   type: realdebrid | alldebrid | torbox | debridlink
#   api_key: leave blank to pick up from env vars RD_API_KEY / AD_API_KEY / TB_API_KEY / DL_API_KEY
#   Omit provider_checks entirely to skip the API check (symlink resolution is the real gate)
#
# Multiple providers on one path:
#   provider_checks:
#     - type: realdebrid
#       api_key: ""
#     - type: alldebrid
#       api_key: ""
#
# Cron reference:
#   "*/30 * * * *"  every 30 min
#   "0 * * * *"     every hour
#   "0 */2 * * *"   every 2 hours
#   "0 2 * * *"     daily at 2am
#
# min_files / min_threshold guidance:
#   min_files    — absolute floor. If mount dies, disk count drops to ~0.
#                  Set to ~10% of your library size as a safe floor.
#   min_threshold — ratio check. 90 means disk files must be >= 90% of Plex count.
#                  Catches partial mount issues without false-positives from normal fluctuation.
